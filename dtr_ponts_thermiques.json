  "liaisons_mur_menuiserie": {
    "source": "Tableau 4.1, p. 61",
    "cas": [
      {
        "type_isolation": "repartie",
        "position": "nu intérieur",
        "formule": "0",
        "conditions": "Menuiserie au nu intérieur"
      },
      {
        "type_isolation": "repartie",
        "position": "ébrasement",
        "formule": "0.4 * e / (Rm + 0.15)",
        "conditions": "Menuiserie en ébrasement"
      },
      {
        "type_isolation": "repartie",
        "position": "nu extérieur",
        "formule": "0.4 * e / (Rm + 0.15)",
        "conditions": "Menuiserie au nu extérieur"
      },
      {
        "type_isolation": "exterieure",
        "position": "nu intérieur, isolation arrêtée",
        "formule": "0.4 * e / (Rm + 0.15)",
        "conditions": "Menuiserie au nu intérieur, isolation arrêtée au droit du tableau"
      },
      {
        "type_isolation": "exterieure",
        "position": "nu intérieur, isolation recouvrant",
        "formule": "0",
        "conditions": "Menuiserie au nu intérieur, isolation recouvrant le tableau"
      },
      {
        "type_isolation": "exterieure",
        "position": "nu extérieur",
        "formule": "0",
        "conditions": "Menuiserie au nu extérieur ou presque"
      },
      {
        "type_isolation": "interieure",
        "position": "nu extérieur, isolation arrêtée",
        "formule": "0.4 * e / (Rm + 0.15)",
        "conditions": "Menuiserie au nu extérieur, isolation arrêtée au droit du tableau"
      },
      {
        "type_isolation": "interieure",
        "position": "nu extérieur, isolation recouvrant",
        "formule": "0",
        "conditions": "Menuiserie au nu extérieur, isolation recouvrant le tableau"
      },
      {
        "type_isolation": "interieure",
        "position": "nu intérieur",
        "formule": "0",
        "conditions": "Menuiserie au nu intérieur ou presque"
      }
    ],
    "notations": {
      "e": "épaisseur du mur sans isolant (m)",
      "Rm": "résistance thermique du mur sans résistances superficielles (m²·°C/W)"
    }
  },
  "liaisons_deux_parois_exterieures": {
    "source": "Tableaux 4.2, 4.3, 4.4, p. 62-64",
    "cas": [
      {
        "type": "isolation répartie, parois identiques",
        "formule": "0.2 * K * e",
        "notations": { "K": "moyenne des K des deux parois sans isolant", "e": "épaisseur moyenne sans isolant" }
      },
      {
        "type": "isolation répartie, parois différentes",
        "formule": "0.2 * e1 / (0.2 + R2) * e2",
        "notations": { "e1": "épaisseur paroi ne faisant pas l'angle", "R2": "résistance paroi faisant l'angle", "e2": "épaisseur paroi faisant l'angle" }
      },
      {
        "type": "angle avec poteau béton",
        "formule": "0.45 * e",
        "notations": { "e": "épaisseur du poteau" }
      },
      {
        "type": "isolation intérieure, angle rentrant, parois identiques",
        "formule": "0.6 * K * e"
      },
      {
        "type": "isolation intérieure, angle rentrant, parois différentes",
        "formule": "0.6 * K2 * e",
        "notations": { "K2": "K de la paroi faisant l'angle sans isolant" }
      },
      {
        "type": "isolation extérieure, angle saillant, parois identiques",
        "formule": "0.6 * K * e"
      },
      {
        "type": "isolation extérieure, angle saillant, parois différentes",
        "formule": "0.6 * K2 * e"
      },
      {
        "type": "isolation répartie + isolation intérieure",
        "formule": "0.4 * e / (R2 + 0.15) + 0.4 * e1 / (R1 + 0.15)",
        "source": "Tableau 4.3, p. 63"
      },
      {
        "type": "isolation intérieure + isolation extérieure, angle saillant",
        "formule": "0.3 * e1 * (1+α) / (0.06 + R1 + R'2)",
        "source": "Tableau 4.4, p. 64",
        "notations": { "α": "coefficient donné par tableau 4.7" }
      },
      {
        "type": "isolation intérieure + isolation extérieure, angle rentrant",
        "formule": "-0.30 * e1 * (1+α) / (0.06 + 0.5*R1 + R'2)",
        "source": "Tableau 4.4, p. 64"
      }
    ]
  },
  "liaisons_paroi_exterieure_interieure": {
    "source": "Tableaux 4.5, 4.6, p. 65-66",
    "cas": [
      {
        "type": "paroi extérieure isolation répartie, paroi intérieure non isolée",
        "formule": "0.4 * e / (R + 0.15)"
      },
      {
        "type": "paroi extérieure isolation répartie, paroi intérieure isolée (r_i ≥ 0.3)",
        "formule": "0.4 * e / (R + 0.25)"
      },
      {
        "type": "paroi extérieure isolation extérieure, paroi intérieure non isolée",
        "formule": "0.4 * e / (R + 0.15)"
      },
      {
        "type": "paroi extérieure isolation extérieure, paroi intérieure partiellement isolée (longueur l)",
        "formule": "0.4 * e * (1+α) / (R + 0.15) + rs",
        "source": "Tableau 4.6, p. 66"
      },
      {
        "type": "paroi extérieure isolation extérieure, paroi intérieure revêtue sur trois faces",
        "formule": "0.4 * e * (1+α) / (R + 0.15) + rs",
        "source": "Tableau 4.6, p. 66"
      },
      {
        "type": "paroi extérieure isolation intérieure, paroi intérieure non isolée",
        "formule": "0.4 * e / (R + 0.15)"
      },
      {
        "type": "paroi extérieure isolation intérieure, paroi intérieure revêtue sur deux faces (r_i' ≥ 0.5)",
        "formule": "0.4 * e * (1+α) / (R + 0.25) + rs"
      }
    ]
  },
